{
  "name": "book-summarizer-rag",
  "version": "1.0.0",
  "description": "Multi-agent, multi-tool RAG pipeline that reads a PDF book and produces a structured summary using LangChain, LangGraph, and a local Ollama LLM (via its OpenAI-compatible API).",
  "type": "module",
  "main": "summarize.js",
  "bin": {
    "summarize-book": "./summarize.js"
  },
  "scripts": {
    "start": "node summarize.js",
    "summarize": "node summarize.js"
  },
  "dependencies": {
    "@langchain/core": "^0.3.40",
    "@langchain/langgraph": "^0.2.44",
    "@langchain/openai": "^0.4.4",
    "dotenv": "^16.4.7",
    "langchain": "^0.3.15",
    "pdf-parse": "^1.1.1",
    "zod": "^3.24.1"
  },
  "engines": {
    "node": ">=18.18"
  },
  "license": "MIT"
}
